DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
JWT_SECRET=change-this-in-production
PORT=4000
CLIENT_ORIGIN=http://localhost:3000
VITE_API_URL=http://localhost:4000/api

# Optional email configuration
# Leave these commented for local development.
# When configured, signup can send real verification and welcome emails.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=GameXchange <noreply@gamexchange.com>

# Optional Razorpay configuration
# Leave these commented for local development.
# When configured, checkout uses real Razorpay orders and payment verification.
# RAZORPAY_KEY_ID=rzp_test_your_key_id
# RAZORPAY_KEY_SECRET=your_key_secret
