# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=change-this-in-production

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=4000
CLIENT_ORIGIN=http://localhost:3000
VITE_API_URL=http://localhost:4000/api

# ============================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ============================================
# REQUIRED for email verification and notifications
#
# Setup Instructions:
# 1. Go to https://myaccount.google.com/security
# 2. Enable "2-Step Verification" if not already enabled
# 3. Go to https://myaccount.google.com/apppasswords
# 4. Select "Mail" and "Other (Custom name)"
# 5. Enter "GameXchange" as the name
# 6. Click "Generate"
# 7. Copy the 16-character password (remove spaces)
# 8. Paste it in SMTP_PASS below
#
# See detailed guide: docs/GMAIL_SMTP_SETUP_GUIDE.md

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-character-app-password
SMTP_FROM=GameXchange <your-email@gmail.com>

# Example configuration:
# SMTP_USER=gamexchange.platform@gmail.com
# SMTP_PASS=abcdefghijklmnop
# SMTP_FROM=GameXchange <gamexchange.platform@gmail.com>

# ============================================
# ALTERNATIVE EMAIL SERVICES
# ============================================
# SendGrid (Recommended for production):
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key
#
# Mailgun:
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=postmaster@your-domain.mailgun.org
# SMTP_PASS=your-mailgun-password

# ============================================
# ENCRYPTION (Optional - for credential storage)
# ============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY=your-64-character-hex-key-here
